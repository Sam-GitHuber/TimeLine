# TimeLine PRODUCTION secrets — template.
#
# On the server: copy this to `.env.prod`, fill in real values, and NEVER commit
# it (.env.prod is gitignored). docker-compose.prod.yml reads it via `env_file`.
#
#   cp .env.prod.example .env.prod
#   # then edit .env.prod with the real secrets below
#
# ---------------------------------------------------------------------------

# --- Postgres ---------------------------------------------------------------
POSTGRES_DB=timeline
POSTGRES_USER=timeline
# Use a long random password. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=CHANGE_ME_long_random_db_password

# --- Django -----------------------------------------------------------------
# Generate a real 50+ char secret key with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"
# (The app refuses to boot with DEBUG off and no real key — that's intentional.)
DJANGO_SECRET_KEY=CHANGE_ME_generate_a_real_secret_key

# Production: DEBUG must be OFF.
DJANGO_DEBUG=false

# The domain(s) the site answers on. For a first LAN test before DNS, add the
# server's LAN IP too, e.g. "your-timeline.net,192.168.1.95".
DJANGO_ALLOWED_HOSTS=your-timeline.net

# Same-origin serving: the SPA and API share this HTTPS origin. This value also
# becomes CSRF_TRUSTED_ORIGINS, so mutating requests are accepted.
DJANGO_CORS_ALLOWED_ORIGINS=https://your-timeline.net

# Send auth/session/CSRF cookies only over HTTPS. Must be true in production.
DJANGO_COOKIE_SECURE=true

# HSTS ("HTTPS only, remember it") — leave 0 until the site is proven stable on
# HTTPS, then raise to 2592000 (30 days) and later 31536000 (1 year).
# DJANGO_HSTS_SECONDS=0

# --- Outbound email (Resend) ------------------------------------------------
# Needed for password recovery and any other mail. Setup (create account, add
# your-timeline.net, paste the SPF/DKIM records into Cloudflare DNS, grab an API
# key) is documented in docs/deploy.md → "Outbound email". Any SMTP provider
# works — just change these values. With EMAIL_HOST set the app fails to boot if
# it's later removed, so a broken deploy can't silently swallow (or log) mail.
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
# Resend uses the literal username "resend"; the password is the API key.
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=CHANGE_ME_resend_api_key
# From address — must be on the domain you verified with the provider.
DEFAULT_FROM_EMAIL=TimeLine <no-reply@your-timeline.net>
# How long (seconds) a single send may block before giving up — keeps a slow or
# unreachable provider from tying up a worker. Optional; defaults to 10.
# EMAIL_TIMEOUT=10
#
# LAN test only: if you want to bring the prod stack up *before* you have a
# provider, comment out EMAIL_HOST above and set this to true. Mail is then
# printed to the backend logs instead of sent. Do NOT enable in real production —
# password-reset links get written to the logs in plaintext.
# EMAIL_CONSOLE_FALLBACK=false

# ---------------------------------------------------------------------------
# Push notifications (Phase 9). The backend queues pushes into PushOutbox and
# `manage.py send_pushes` delivers them via Expo, which fans out to APNs/FCM —
# so no APNs key lives here; that stays with EAS.
#
# Optional but recommended in production. Expo accepts unauthenticated sends,
# but once a token is set it *rejects* sends without it — which is what stops
# anyone who learns one of your users' Expo push tokens from pushing to them
# under your app's name. Create at expo.dev → Account settings → Access tokens.
# EXPO_ACCESS_TOKEN=CHANGE_ME_expo_access_token
#
# Tuning (both optional, sensible defaults in settings.py):
#   EXPO_PUSH_BATCH_SIZE      — *messages* per Expo request. Default 100 (Expo's
#                               documented maximum); lower it only to throttle.
#   EXPO_PUSH_MAX_ROWS        — *outbox rows* drained per run. Default 200. Not
#                               the same count as above: one notification fans
#                               out to every device its recipient owns.
#   EXPO_PUSH_RETENTION_DAYS  — how long delivered rows are kept as a delivery
#                               log before pruning. Default 14.

# ---------------------------------------------------------------------------
# The two settings below are read by docker-compose.prod.yml itself (not Django),
# and already default to the public domain — you only need them for a LAN test:
#
#   SITE_ADDRESS   — Caddy's site + TLS. ":80" = plain HTTP, no certs (LAN test).
#                    Default (unset): your-timeline.net with automatic HTTPS.
#   VITE_API_URL   — API origin baked into the SPA at build time.
#                    Default (unset): https://your-timeline.net
#
# Example LAN test (no domain, no HTTPS) — pass them on the command line:
#   SITE_ADDRESS=:80 VITE_API_URL=http://192.168.1.95 \
#     docker compose -f docker-compose.prod.yml up -d --build
