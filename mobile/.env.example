# Copy to `.env` to point the app at a backend other than the default.
#
# The default (no .env at all) is the Phase 7 home server, https://your-timeline.net
# — which is what you normally want, including in the Simulator: the Simulator
# can't reach the host's localhost:8000 the way a desktop browser can.
#
# Set this only when you're debugging API work against a local Django. Use your
# machine's LAN IP, not "localhost", or the Simulator/device won't find it.
#
#   EXPO_PUBLIC_API_URL=http://192.168.1.42:8000
#
# EXPO_PUBLIC_ vars are inlined into the shipped JS bundle, so anyone with the
# app can read them. Never put a secret in one.
EXPO_PUBLIC_API_URL=https://your-timeline.net
