# Copy this file to `.env` and adjust as needed. Docker Compose reads `.env`
# automatically. The values here mirror the safe dev defaults baked into
# docker-compose.yml — you only need a .env to override them.
#
# NEVER commit a real .env with production secrets (it is gitignored).

# --- Postgres ---
POSTGRES_DB=timeline
POSTGRES_USER=timeline
POSTGRES_PASSWORD=timeline

# --- Django ---
# Generate a real one for anything non-local:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=django-insecure-dev-only-key-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Frontend ---
VITE_API_URL=http://localhost:8000
