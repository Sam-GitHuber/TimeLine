# TimeLine off-site BACKUP config — template.
#
# On the server: copy to /etc/timeline/backup.env, fill in real values, and lock
# it down (it names your remote + tuning, not raw secrets — those live in
# rclone's own config — but keep it root/user-only anyway):
#
#   sudo mkdir -p /etc/timeline
#   sudo cp deploy/backup.env.example /etc/timeline/backup.env
#   sudo nano /etc/timeline/backup.env
#   sudo chown "$USER:$USER" /etc/timeline/backup.env   # backup runs as this user
#   sudo chmod 600 /etc/timeline/backup.env
#
# backup.sh sources this file. See docs/backup-restore.md for the full setup
# (creating the R2 bucket + the encrypted rclone remote this points at).
# ---------------------------------------------------------------------------

# The rclone remote to push to. This MUST be the ENCRYPTED (crypt) remote, not
# the raw R2 one — everything leaving the house is encrypted at rest. Set up in
# docs/backup-restore.md; conventionally named "timeline-crypt". Include a
# trailing colon; backup.sh appends /db and /media under it.
RCLONE_REMOTE=timeline-crypt:

# Where the app's live media tree lives on the NVMe (source of the media sync).
MEDIA_DIR=/srv/timeline/media

# Local staging dir for DB dumps before they're uploaded (on the NVMe data disk).
# Kept as a fast local restore source too; pruned to LOCAL_KEEP most-recent.
LOCAL_STAGE=/srv/timeline/backups

# How many most-recent DB dumps to keep on the LOCAL disk (quick restore source).
LOCAL_KEEP=7

# How many days of DB dumps to keep OFF-SITE (R2). Dumps are tiny (compressed
# SQL), so a long history is cheap — 30 daily dumps is typically tens of MB.
DB_KEEP_DAYS=30

# Media is mirrored (rclone sync), so off-site media storage ≈ your LIVE media
# size, NOT multiplied by retention. Files that get changed/deleted locally are
# moved into a dated archive on R2 instead of being deleted outright (guards
# against a local wipe propagating up). Keep that archive this many days.
MEDIA_ARCHIVE_KEEP_DAYS=30

# The production compose file (relative to the repo root). backup.sh runs
# pg_dump inside the `db` service defined here.
COMPOSE_FILE=docker-compose.prod.yml

# OPTIONAL but strongly recommended: a dead-man's-switch URL pinged only when a
# backup SUCCEEDS (e.g. a free healthchecks.io check). If the nightly ping stops
# arriving, you get alerted — otherwise a broken backup fails silently, which is
# the single most dangerous backup failure mode. Leave blank to disable.
HEALTHCHECK_URL=
