# TimeLine uptime HEALTHCHECK config — template.
#
# On the server: copy to /etc/timeline/healthcheck.env, fill in PING_URL, and
# lock it down (PING_URL is a secret-ish token — anyone with it can spoof
# "healthy" pings for your check):
#
#   sudo mkdir -p /etc/timeline
#   sudo cp deploy/healthcheck.env.example /etc/timeline/healthcheck.env
#   sudo nano /etc/timeline/healthcheck.env
#   sudo chown "$USER:$USER" /etc/timeline/healthcheck.env   # check runs as this user
#   sudo chmod 600 /etc/timeline/healthcheck.env
#
# healthcheck.sh sources this file. See docs/deploy.md ("Uptime monitoring") for
# the one-time healthchecks.io setup that produces the PING_URL below.
# ---------------------------------------------------------------------------

# REQUIRED: the healthchecks.io ping URL for the UPTIME check (a DIFFERENT check
# from the backup one). Looks like https://hc-ping.com/<uuid>. healthcheck.sh
# pings this on success and pings "<PING_URL>/fail" on failure.
PING_URL=

# The health endpoint to probe. The default is fine for the standard deploy.
TARGET_URL=https://your-timeline.net/api/healthz/

# curl --resolve override so the public hostname connects to loopback — this
# tests Caddy's real cert + routing + the app WITHOUT needing the router to
# "hairpin" (route a LAN request to your own public IP back inside), which many
# home routers can't do. Leave as-is unless your domain differs. Set it EMPTY to
# instead probe over the real internet path (only do this if you've confirmed
# hairpin works on your router, or you'll get false "down" alerts).
RESOLVE=your-timeline.net:443:127.0.0.1

# Seconds to wait for the site before declaring it down.
CURL_MAX_TIME=15

# Seconds to wait when pinging healthchecks.io (keeps a slow ping from hanging
# the timer).
PING_MAX_TIME=10
