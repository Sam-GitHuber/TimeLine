# Cloudflare DDNS config for the TimeLine home server — TEMPLATE.
#
# On the server:
#   sudo mkdir -p /etc/timeline
#   sudo cp deploy/cloudflare-ddns.env.example /etc/timeline/cloudflare-ddns.env
#   sudo nano /etc/timeline/cloudflare-ddns.env      # paste the real token
#   sudo chmod 600 /etc/timeline/cloudflare-ddns.env
#
# Holds a secret (the API token) so it lives OUTSIDE the repo, root-owned, 600.

# Cloudflare API token, scoped to Edit zone DNS for your-timeline.net only.
CF_API_TOKEN=paste_your_cloudflare_api_token_here

# The Cloudflare zone (your registered domain).
CF_ZONE_NAME=your-timeline.net

# The DNS record to keep updated (usually the same as the zone for the apex).
CF_RECORD_NAME=your-timeline.net
